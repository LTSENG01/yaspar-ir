(assert (not (= f1 f2)))
(assert (let ((?v_0 0.0)) (let ((?v_2 (< ?v_0 f3)) (?v_1 (not (= (f5 f3) ?v_0))) (?v_4 (not (= (f6 f3) 1.0))) (?v_3 (< f3 (* 2.0 f4)))) (not (=> (=> ?v_2 (=> (< f3 f4) ?v_1)) (=> (=> (= f3 f4) ?v_4) (=> (=> (< f4 f3) (=> ?v_3 ?v_1)) (=> ?v_2 (=> ?v_3 (or ?v_1 ?v_4))))))))))
